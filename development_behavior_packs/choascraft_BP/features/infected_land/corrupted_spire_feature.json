      "minecraft:fern",
      "zombie:abyss_grass",
      "zombie:abyss_mushroom",
      "zombie:abyss_glob_flower",
      "zombie:abyss_flower",
      "zombie:glow_flower",
      "zombie:black_grass",
      "zombie:eye_flower",
      "zombie:infected_flower",
      "zombie:infected_mushroom",
      "zombie:sporepod"
    ],
    "may_attach_to": {
      "bottom": [
        "zombie:infected_grass_block",
        "zombie:infected_sand",
        "zombie:infected_gravel",
        "zombie:infected_stone"
      ]
    }
  }
}
