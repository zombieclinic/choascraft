    "components": {
      "minecraft:health": { "value": 1500, "max": 1500 },
      "minecraft:attack": { "damage": 20 },
      "minecraft:collision_box": { "width": 1.4, "height": 3.4 },
      "minecraft:scale": { "value": 1 },
      "minecraft:fire_immune": {},
      "minecraft:physics": {},
      "minecraft:nameable": {},
      "minecraft:type_family": { "family": ["demon_lord", "demon", "monster", "mob"] },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0,
        "breathes_air": true,
        "breathes_water": true
      },
      "minecraft:behavior.hurt_by_target": { "priority": 1 },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 2,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 40,
        "entity_types": [{
          "filters": { "any_of": [
            { "test": "is_family", "subject": "other", "value": "player" },
            { "test": "is_family", "subject": "other", "value": "irongolem" },
            { "test": "is_family", "subject": "other", "value": "snowgolem" }
          ]},
          "max_dist": 40
        }]
      },
      "minecraft:behavior.random_stroll": { "priority": 7, "speed_multiplier": 1 },
      "minecraft:behavior.look_at_player": { "priority": 8, "look_distance": 12 },
      "minecraft:behavior.random_look_around": { "priority": 9 }
    },
    "events": {
      "minecraft:entity_spawned": { "add": { "component_groups": ["phase_one", "melee_mode"] } },
      "enter_melee_mode": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": false,
              "zombie:thorn_skill": false,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["thorn_cast", "minion_check", "minion_cast"]
            }
          },
          {
            "add": {
              "component_groups": ["melee_mode"]
            }
          }
        ]
      },
      "enter_ranged_mode": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": true,
              "zombie:thorn_skill": true,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["melee_mode"]
            }
          },
          {
            "add": {
              "component_groups": ["thorn_cast"]
            }
          }
        ]
      },
      "begin_second_stage": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": false,
              "zombie:thorn_skill": false,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": { "component_groups": ["phase_one", "melee_mode", "thorn_cast", "minion_check", "minion_cast"] }
          },
          {
            "add": { "component_groups": ["second_stage"] }
          }
        ]
      },
      "enter_fast_mode": {
        "remove": { "component_groups": ["second_stage"] },
        "add": { "component_groups": ["fast_mode", "melee_mode"] }
      },
      "begin_death": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": false,
              "zombie:thorn_skill": false,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["phase_one", "second_stage", "fast_mode", "melee_mode", "thorn_cast", "minion_check", "minion_cast"]
            }
          },
          {
            "add": {
              "component_groups": ["dying"]
            }
          }
        ]
      },
      "finish_thorn_skill": {
        "sequence": [
          {
            "set_property": {
              "zombie:thorn_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["thorn_cast"]
            }
          },
          {
            "add": {
              "component_groups": ["minion_check"]
            }
          }
        ]
      },
      "skip_minion_summon": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": false,
              "zombie:thorn_skill": false,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["thorn_cast", "minion_check", "minion_cast"]
            }
          },
          {
            "add": {
              "component_groups": ["melee_mode"]
            }
          }
        ]
      },
      "summon_minion": {
        "sequence": [
          {
            "set_property": {
              "zombie:minion_skill": true
            }
          },
          {
            "remove": {
              "component_groups": ["minion_check"]
            }
          },
          {
            "add": {
              "component_groups": ["minion_cast"]
            }
          }
        ]
      },
      "finish_minion_skill": {
        "sequence": [
          {
            "set_property": {
              "zombie:ranged_mode": false,
              "zombie:thorn_skill": false,
              "zombie:minion_skill": false
            }
          },
          {
            "remove": {
              "component_groups": ["thorn_cast", "minion_check", "minion_cast"]
            }
          },
          {
            "add": {
              "component_groups": ["melee_mode"]
            }
          }
        ]
      },
      "finish_death": {
        "add": { "component_groups": ["despawn_now"] }
      },
      "despawn": { "add": { "component_groups": ["despawn_now"] } }
    }
  }
}
