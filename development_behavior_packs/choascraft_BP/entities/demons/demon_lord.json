        "zombie:minion_skill": {
          "type": "bool",
          "default": false,
          "client_sync": true
        }
      }
    },
    "component_groups": {
      "phase_one": {
        "minecraft:variant": { "value": 1 },
        "minecraft:damage_sensor": {
          "triggers": [
            {
              "deals_damage": "no",
              "on_damage": {
                "filters": [
                  {
                    "test": "actor_health",
                    "subject": "self",
                    "operator": "<=",
                    "value": 700
                  }
                ],
                "event": "begin_second_stage"
              }
            }
          ]
        },
        "minecraft:movement": { "value": 0.18 },
        "minecraft:movement.basic": {},
        "minecraft:navigation.walk": {
          "is_amphibious": true,
          "can_walk": true,
          "can_pass_doors": true,
          "can_break_doors": true
        },
        "minecraft:jump.static": {}
