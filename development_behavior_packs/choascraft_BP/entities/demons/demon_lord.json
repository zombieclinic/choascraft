              ]
            },
            {
              "weight": 1,
              "do_casting": true,
              "cooldown_time": 0,
              "cast_duration": 3.0417,
              "min_activation_range": 0,
              "max_activation_range": 40,
              "sequence": [
                {
                  "shape": "circle",
                  "target": "self",
                  "base_delay": 1.5,
                  "num_entities_spawned": 1,
                  "entity_type": "zombie:emberstalker",
                  "summon_cap": 1,
                  "summon_cap_radius": 20,
                  "size": 2
                }
              ]
            }
          ]
        },
        "minecraft:target_nearby_sensor": {
          "inside_range": 4,
          "outside_range": 4,
          "must_see": false,
          "on_inside_range": {
            "event": "enter_melee_mode",
            "target": "self"
          }
