      "spawn_category": "monster",
      "is_spawnable": true,
      "is_summonable": true,
      "properties": {
        "zombie:thorn_skill": {
          "type": "bool",
          "default": false,
          "client_sync": true
        },
        "zombie:ranged_mode": {
          "type": "bool",
          "default": false,
          "client_sync": false
