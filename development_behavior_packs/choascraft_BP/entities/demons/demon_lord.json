          "inside_range": 4,
          "outside_range": 4,
          "must_see": false,
          "on_outside_range": {
            "event": "enter_ranged_mode",
            "target": "self"
          }
        }
      },
      "dying": {
        "minecraft:variant": { "value": 10 },
        "minecraft:damage_sensor": {
          "triggers": [{ "deals_damage": "no" }]
        },
        "minecraft:timer": {
          "time": 5,
          "looping": false,
          "time_down_event": { "event": "finish_death", "target": "self" }
        }
      },
      "despawn_now": {
        "minecraft:instant_despawn": {
          "remove_child_entities": true
        }
      },
      "thorn_cast": {
        "minecraft:behavior.summon_entity": {
          "priority": 0,
          "control_flags": ["look", "move"],
          "summon_choices": [
            {
              "weight": 1,
              "do_casting": true,
              "cooldown_time": 0,
              "cast_duration": 2.25,
              "min_activation_range": 4,
              "max_activation_range": 40,
              "sequence": [
                {
                  "shape": "circle",
                  "target": "target",
                  "base_delay": 0.75,
                  "num_entities_spawned": 1,
                  "entity_type": "zombie:demon_lord_claw",
                  "summon_cap": 1,
                  "summon_cap_radius": 2,
                  "size": 0
                }
              ]
            }
          ]
        },
        "minecraft:target_nearby_sensor": {
          "inside_range": 4,
          "outside_range": 4,
          "must_see": false,
          "on_inside_range": {
            "event": "enter_melee_mode",
            "target": "self"
          }
        },
        "minecraft:timer": {
          "time": 2.25,
          "looping": false,
          "time_down_event": {
            "event": "finish_thorn_skill",
            "target": "self"
          }
        }
      },
      "minion_check": {
        "minecraft:entity_sensor": {
          "relative_range": false,
          "subsensors": [
            {
              "event": "skip_minion_summon",
              "minimum_count": 1,
              "range": [20, 20],
              "require_all": false,
              "event_filters": {
                "test": "is_family",
                "subject": "other",
                "value": "demon_minion"
              }
            },
            {
              "event": "summon_minion",
              "minimum_count": 0,
              "maximum_count": 0,
              "range": [20, 20],
              "require_all": false,
              "event_filters": {
                "test": "is_family",
                "subject": "other",
                "value": "demon_minion"
              }
            }
          ]
        },
        "minecraft:target_nearby_sensor": {
          "inside_range": 4,
          "outside_range": 4,
          "must_see": false,
          "on_inside_range": {
            "event": "enter_melee_mode",
            "target": "self"
          }
        }
      },
      "minion_cast": {
        "minecraft:behavior.summon_entity": {
          "priority": 0,
          "control_flags": ["look", "move"],
          "summon_choices": [
            {
              "weight": 1,
              "do_casting": true,
              "cooldown_time": 0,
              "cast_duration": 3.0417,
              "min_activation_range": 0,
              "max_activation_range": 40,
              "sequence": [
                {
                  "shape": "circle",
                  "target": "self",
