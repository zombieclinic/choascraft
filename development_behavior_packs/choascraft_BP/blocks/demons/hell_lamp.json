{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "zombie:hell_lamp",
      "menu_category": {
        "category": "items"
      },
      "traits": {
        "minecraft:placement_position": {
          "enabled_states": [
            "minecraft:block_face"
          ]
        }
      }
    },
    "components": {
      "minecraft:display_name": "Hell Lamp",
      "minecraft:geometry": "geometry.hell_lamp",
      "minecraft:material_instances": {
        "*": {
          "texture": "zombie_hell_lamp",
          "render_method": "opaque"
        }
      },
      "minecraft:collision_box": true,
      "minecraft:selection_box": true,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:destructible_by_explosion": true,
      "minecraft:light_emission": 15,
      "minecraft:flammable": false,
      "minecraft:tags": [
        "minecraft:is_pickaxe_item_destructible"
      ],
      "minecraft:map_color": "#361103"
    },
    "permutations": [
      {
        "condition": "query.block_state('minecraft:block_face') == 'down'",
        "components": {
          "minecraft:geometry": "geometry.hell_lamp_ceiling",
          "minecraft:collision_box": true,
          "minecraft:selection_box": true
        }
      },
      {
        "condition": "query.block_state('minecraft:block_face') == 'up'",
        "components": {
          "minecraft:geometry": "geometry.hell_lamp",
          "minecraft:collision_box": true,
          "minecraft:selection_box": true
        }
      }
    ]
  }
}

