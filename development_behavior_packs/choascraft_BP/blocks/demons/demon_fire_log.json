{
  "format_version": "1.26.20",
  "minecraft:block": {
    "description": {
      "identifier": "zombie:demon_fire_log",
      "traits": {
        "minecraft:placement_position": {
          "enabled_states": [
            "minecraft:block_face"
          ]
        }
      },
      "menu_category": {
        "category": "nature",
        "group": "minecraft:itemGroup.name.log"
      }
    },
    "components": {
      "minecraft:geometry": "minecraft:geometry.full_block",
      "minecraft:material_instances": {
        "*": {
          "texture": "zombie_hell_log2",
          "ambient_occlusion": 1,
          "face_dimming": true,
          "render_method": "opaque"
        },
        "up": {
          "texture": "zombie_demon_log_top"
        },
        "down": {
          "texture": "zombie_demon_log_top"
        }
      },
      "minecraft:collision_box": true,
      "minecraft:destructible_by_explosion": true,
      "minecraft:display_name": "Embervein Hellwood Log",
      "minecraft:light_emission": 1,
      "minecraft:flammable": false,
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 1
      },
      "minecraft:selection_box": true,
      "minecraft:tags": [
        "minecraft:is_axe_item_destructible"
      ],
      "minecraft:map_color": "#2C120F"
    },
    "permutations": [
      {
        "condition": "q.block_state('minecraft:block_face') == 'north' || q.block_state('minecraft:block_face') == 'south' ",
        "components": {
          "minecraft:transformation": {
            "rotation": [
              90,
              0,
              0
            ]
          }
        }
      },
      {
        "condition": "q.block_state('minecraft:block_face') == 'east' || q.block_state('minecraft:block_face') == 'west' ",
        "components": {
          "minecraft:transformation": {
            "rotation": [
              0,
              90,
              -90
            ]
          }
        }
      }
    ]
  }
}

