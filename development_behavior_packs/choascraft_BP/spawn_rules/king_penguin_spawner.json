{
  "format_version": "1.8.0",
  "minecraft:spawn_rules": {
    "description": {
      "identifier": "zombie:king_penguin_spawner",
      "population_control": "animal"
    },
    "conditions": [
      {
        "minecraft:spawns_on_surface": {
          
        },
        "minecraft:weight": {
          "default": 4
        },
        "minecraft:density_limit": {
          "surface": 5,
          "underground": 0
        },
        "minecraft:herd": {
          "min_size": 2,
          "max_size": 5
        },
        "minecraft:height_filter": {
          "min": 60,
          "max": 90
        },
        "minecraft:spawns_on_block_filter": [
          "minecraft:snow",
          "minecraft:ice",
          "minecraft:packed_ice",
          "minecraft:blue_ice",
          "minecraft:sand"
        ],
        "minecraft:spawn_event": {
          "event": "minecraft:entity_spawned"
        },
        "minecraft:biome_filter": {
          "any_of": [
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "cold"
            },
            {
              "test": "has_biome_tag",
              "operator": "==",
              "value": "frozen"
            }
          ]
        }
      }
    ]
  }
}

