{
  "format_version": "1.26.20",
  "minecraft:attachable": {
    "description": {
      "identifier": "zombie:chaos_shield",
      "materials": {
        "enchanted": "entity_alphatest_glint",
        "default": "entity_alphatest"
      },
      "geometry": {
        "default": "geometry.demon_shield",
        "blocking": "geometry.demon_shield_blocking",
        "left_hold": "geometry.chaos_left_sheild_hold",
        "left_blocking": "geometry.chaos_sheild_left_blocking"
      },
      "textures": {
        "default": "textures/demon/item_mob/chaos_gear",
        "enchanted": "textures/misc/enchanted_item_glint"
      },
      "render_controllers": [
        "controller.render.choas_sheild"
      ],
      "animations": {
        "fpp_idle": "animation.demon_shield.shield_fpp",
        "blocking_idle": "animation.demon_shield_blocking.fpp_idle"
      },
      "scripts": {
        "animate": [
          {
            "blocking_idle": "c.is_first_person && query.is_using_item == true && query.is_item_name_any('slot.weapon.mainhand', 0, 'zombie:chaos_shield')"
          },
          {
            "fpp_idle": "c.is_first_person && query.is_using_item == false && query.is_item_name_any('slot.weapon.mainhand', 0, 'zombie:chaos_shield')"
          }
        ]
      }
    }
  }
}

