{
  "format_version": "1.8.0",
  "animations": {
    "animation.zombie.king_penguin.idle": {
      "loop": true,
      "bones": {
        "body": {
          "rotation": [
            "Math.sin(query.life_time * 70) * 1",
            0,
            0
          ]
        },
        "head": {
          "rotation": [
            "Math.sin(query.life_time * 55) * 2",
            0,
            0
          ]
        },
        "left_flipper": {
          "rotation": [
            0,
            0,
            "-8 + Math.sin(query.life_time * 65) * 2"
          ]
        },
        "right_flipper": {
          "rotation": [
            0,
            0,
            "8 - Math.sin(query.life_time * 65) * 2"
          ]
        }
      }
    },
    "animation.zombie.king_penguin.walk": {
      "loop": true,
      "bones": {
        "body": {
          "rotation": [
            0,
            0,
            "Math.sin(query.modified_move_speed * 60 + query.life_time * 220) * 4"
          ]
        },
        "left_foot": {
          "rotation": [
            "Math.sin(query.life_time * 230) * 22",
            0,
            0
          ]
        },
        "right_foot": {
          "rotation": [
            "Math.sin(query.life_time * 230 + 180) * 22",
            0,
            0
          ]
        },
        "left_flipper": {
          "rotation": [
            "Math.sin(query.life_time * 230 + 180) * 10",
            0,
            -18
          ]
        },
        "right_flipper": {
          "rotation": [
            "Math.sin(query.life_time * 230) * 10",
            0,
            18
          ]
        }
      }
    },
    "animation.zombie.king_penguin.swim": {
      "loop": true,
      "bones": {
        "root": {
          "rotation": [
            75,
            0,
            0
          ]
        },
        "left_flipper": {
          "rotation": [
            "Math.sin(query.life_time * 360) * 35",
            0,
            -25
          ]
        },
        "right_flipper": {
          "rotation": [
            "Math.sin(query.life_time * 360 + 180) * 35",
            0,
            25
          ]
        },
        "left_foot": {
          "rotation": [
            "Math.sin(query.life_time * 360) * 18",
            0,
            0
          ]
        },
        "right_foot": {
          "rotation": [
            "Math.sin(query.life_time * 360 + 180) * 18",
            0,
            0
          ]
        },
        "head": {
          "relative_to": {
            "rotation": "entity"
          },
          "rotation": [
            0,
            0,
            0.01
          ]
        }
      }
    },
    "animation.zombie.king_penguin.sit": {
      "loop": true,
      "bones": {
        "body": {
          "position": [
            0,
            -2,
            0
          ]
        },
        "left_foot": {
          "rotation": [
            -90,
            0,
            0
          ],
          "position": [
            0,
            2,
            -2
          ]
        },
        "right_foot": {
          "rotation": [
            -90,
            0,
            0
          ],
          "position": [
            0,
            2,
            -2
          ]
        }
      }
    }
  }
}

