{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.zombie.king_penguin": {
      "initial_state": "default",
      "states": {
        "default": {
          "animations": [
            "idle",
            {
              "walk": "query.modified_move_speed > 0.03 && !query.is_in_water"
            },
            {
              "swim": "query.is_in_water"
            }
          ]
        }
      }
    }
  }
}
