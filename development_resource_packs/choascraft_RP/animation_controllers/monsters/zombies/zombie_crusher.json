{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.zombie_crusher": {
      "initial_state": "spawn",
      "states": {
        "spawn": {
          "animations": [
            "spawn"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "idle": "query.all_animations_finished"
            }
          ],
          "sound_effects": [
            {
              "effect": "scream"
            }
          ]
        },
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "walk": "query.ground_speed"
            },
            {
              "attack": "variable.attack_time >= 0.01"
            },
            {
              "charging": "query.is_ram_attacking"
            }
          ]
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "idle": "!query.ground_speed"
            },
            {
              "attack": "variable.attack_time >= 0.01"
            },
            {
              "charging": "query.is_ram_attacking"
            }
          ]
        },
        "attack": {
          "animations": [
            "attack",
            "walk_attack"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "charging": "query.is_ram_attacking"
            },
            {
              "idle": "query.all_animations_finished"
            },
            {
              "walk": "query.ground_speed && query.all_animations_finished"
            }
          ]
        },
        "charging": {
          "animations": [
            "charging"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "charg_hit": "!query.is_ram_attacking"
            }
          ]
        },
        "charg_hit": {
          "animations": [
            "charg_hit"
          ],
          "transitions": [
            {
              "death": "query.variant == 4"
            },
            {
              "walk": "query.ground_speed && query.all_animations_finished"
            },
            {
              "idle": "query.all_animations_finished"
            }
          ]
        },
        "death": {
          "animations": [
            "death"
          ]
        }
      }
    }
  }
}

