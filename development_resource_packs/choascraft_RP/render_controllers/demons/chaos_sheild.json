{
  "format_version": "1.8.0",
  "render_controllers": {
    "controller.render.choas_sheild": {
      "geometry": "query.is_item_name_any('slot.weapon.offhand', 0, 'zombie:chaos_shield') ? (query.is_sneaking ? Geometry.left_blocking : Geometry.left_hold) : ((query.main_hand_item_use_duration > 0 && query.is_item_name_any('slot.weapon.mainhand', 0, 'zombie:chaos_shield')) ? Geometry.blocking : Geometry.default)",
      "materials": [
        {
          "*": "Material.default"
        }
      ],
      "textures": [
        "Texture.default"
      ]
    }
  }
}

